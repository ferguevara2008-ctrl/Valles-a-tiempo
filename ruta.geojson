for(let i = 0; i < rutaCoords.length - 1; i++){

    let color;

    let trafico = Math.random();

    if(trafico < 0.5){
        color = "#22c55e";
    }
    else if(trafico < 0.8){
        color = "#f59e0b";
    }
    else{
        color = "#ef4444";
    }

    L.polyline(
        [rutaCoords[i], rutaCoords[i+1]],
        {
            color: color,
            weight: 8,
            opacity: 1,
            lineCap: "round"
        }
    ).addTo(map);

}

map.fitBounds(rutaCoords);

